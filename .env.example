OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx

# Optional: use ElevenLabs for narration instead of OpenAI TTS.
TTS_PROVIDER=openai
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional: download licensed stock clips for future b-roll/background use.
PEXELS_API_KEY=
PEXELS_QUERY=stock market, finance, money
PEXELS_CLIPS=4

# Optional: more stock clip providers.
COVERR_API_KEY=
COVERR_QUERY=finance
COVERR_CLIPS=4
PIXABAY_API_KEY=
PIXABAY_QUERY=stock market finance
PIXABAY_CLIPS=4

# Optional: cloud rendering. Shotstack can render only from internet-accessible media URLs.
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage

# Optional: Gemini key if you later want to add a Gemini script-generation fallback.
GEMINI_API_KEY=

# YouTube OAuth client from Google Cloud Console.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:53682/oauth2callback

# Upload defaults. Keep private until you manually review the rendered video.
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=25

# Finance assumptions. Override when you want a pinned calculation.
TARGET_MONTHLY_KRW=1000000
JEPQ_ANNUAL_YIELD=0.1031
JEPQ_MONTHLY_DIVIDEND_USD=0.591
US_WITHHOLDING_TAX_RATE=0.15
